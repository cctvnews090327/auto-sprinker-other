local function mkFrame(p,s,pos,col,r)
    local f=Instance.new("Frame",p); f.Size=s; f.Position=pos
    f.BackgroundColor3=col or C.panel; f.BorderSizePixel=0
    if r then Instance.new("UICorner",f).CornerRadius=UDim.new(0,r) end
    return f
end
local function mkLabel(p,t,s,pos,col,fs,bold,xa)
    local l=Instance.new("TextLabel",p); l.BackgroundTransparency=1
    l.Size=s; l.Position=pos; l.Text=t; l.TextColor3=col or C.text
    l.TextSize=fs or 10
    l.Font=bold and Enum.Font.GothamBold or Enum.Font.GothamMedium
    l.TextXAlignment=xa or Enum.TextXAlignment.Left; l.TextWrapped=true
    return l
end
local function mkBtn(p,t,s,pos,bg,fg,cb)
    local b=Instance.new("TextButton",p); b.Size=s; b.Position=pos
    b.BackgroundColor3=bg; b.BorderSizePixel=0; b.Text=t; b.TextColor3=fg
    b.TextSize=10; b.Font=Enum.Font.GothamBold; b.AutoButtonColor=false
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,4)
    if cb then b.MouseButton1Click:Connect(cb) end
    return b
end

