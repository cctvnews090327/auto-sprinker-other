    log(("Destroyed %d plants client-side, kept %s"):format(destroyed, keepOne and keepOne.Name:sub(1,24) or "none"), C.purple)
    log("Rejoin server to restore visibility", C.muted)
end)

-- =====================
-- PRUNE ALL GARDENS (NEW)
-- Scan every garden in the server; if it has plants, destroy
-- all but one client-side. Skips gardens with 0 or 1 plants.
-- =====================
pruneAllBtn.MouseButton1Click:Connect(function()
    local gardensFolder = Workspace:FindFirstChild("Gardens")
    if not gardensFolder then
        log("No Gardens folder in Workspace", C.danger); return
    end

    pruneAllBtn.Active = false
    pruneAllBtn.Text = "Pruning..."
    log("── Prune All Gardens: scanning ──", C.teal)

    task.spawn(function()
        local gardensTouched  = 0
        local gardensSkipped  = 0
        local totalDestroyed  = 0

        for _,garden in ipairs(gardensFolder:GetChildren()) do
            local plants = garden:FindFirstChild("Plants")
            if plants then
                -- Group plants by owner prefix (userId at start of name).
                -- Fallback: if we can't parse an owner, treat the whole
                -- garden as one group.
                local groups = {}
                local order  = {}
                for _,plant in ipairs(plants:GetChildren()) do
                    local ownerKey = plant.Name:match("^(%d+)") or "_all"
                    if not groups[ownerKey] then
                        groups[ownerKey] = {}
                        table.insert(order, ownerKey)
                    end
                    table.insert(groups[ownerKey], plant)
                end

                if #order == 0 then
                    gardensSkipped = gardensSkipped + 1
                else
                    local gardenLabel = garden:GetAttribute("Owner")
                        or garden.Name
                    local gardenDestroyed = 0
                    local gardenKept = 0

                    for _,key in ipairs(order) do
                        local list = groups[key]
                        if #list <= 1 then
                            gardenKept = gardenKept + #list
                        else
                            -- keep first, destroy rest
                            gardenKept = gardenKept + 1
                            for i = 2, #list do
                                pcall(function() list[i]:Destroy() end)
                                gardenDestroyed = gardenDestroyed + 1
                            end
                        end
                    end

                    if gardenDestroyed > 0 then
                        gardensTouched = gardensTouched + 1
                        totalDestroyed = totalDestroyed + gardenDestroyed
                        log(("  %s: kept %d, destroyed %d"):format(
                            tostring(gardenLabel):sub(1,20),
                            gardenKept, gardenDestroyed), C.teal)
                    else
                        gardensSkipped = gardensSkipped + 1
                    end
                    task.wait() -- yield so we don't freeze on huge servers
                end
            else
                gardensSkipped = gardensSkipped + 1
            end
        end

        log(("── Done: %d gardens pruned, %d skipped, %d plants destroyed ──"):format(
            gardensTouched, gardensSkipped, totalDestroyed), C.gold)
        pruneAllBtn.Text = ("🌾 Pruned %d gardens (%d plants)"):format(gardensTouched, totalDestroyed)
        pruneAllBtn.BackgroundColor3 = Color3.fromRGB(20,45,45)
        pruneAllBtn.Active = true
    end)
end)

