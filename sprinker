locateBtn.MouseButton1Click:Connect(function()
    local farmUsername = farmUserInput.Text:match("^%s*(.-)%s*$")
    if farmUsername=="" then
        resolvedLbl.Text="Enter farming account username first"
        resolvedLbl.TextColor3=C.danger; return
    end
    locateBtn.Active=false; locateBtn.Text="Locating..."
    resolvedLbl.Text="Resolving..."; resolvedLbl.TextColor3=C.muted
    resolvedTargetId,resolvedCentroid,resolvedPlotId,resolvedGarden=nil,nil,nil,nil
    fireBtn.Active=false
    fireBtn.BackgroundColor3=Color3.fromRGB(30,15,15)
    fireBtn.TextColor3=Color3.fromRGB(100,40,40)

    task.spawn(function()
        local ok,targetId = pcall(function()
            return Players:GetUserIdFromNameAsync(farmUsername)
        end)
        if not ok or not targetId then
            resolvedLbl.Text="Username not found"; resolvedLbl.TextColor3=C.danger
            locateBtn.Active=true; locateBtn.Text="🔍 Locate Target Plot"; return
        end
        log(("Resolved: %s → ID %d"):format(farmUsername,targetId),C.accent)

        local garden = getTargetGarden(targetId,farmUsername)
        if not garden then
            resolvedLbl.Text=("%s not in this server"):format(farmUsername)
            resolvedLbl.TextColor3=C.danger
            locateBtn.Active=true; locateBtn.Text="🔍 Locate Target Plot"; return
        end
        local centroid = getTargetPlotCentroid(garden,targetId)
        if not centroid then
            resolvedLbl.Text=("%s has no plants"):format(farmUsername)
            resolvedLbl.TextColor3=C.danger
            locateBtn.Active=true; locateBtn.Text="🔍 Locate Target Plot"; return
        end

        local plotId = tonumber((garden.Name:match("Plot(%d+)"))) or lp:GetAttribute("PlotId")

        resolvedTargetId=targetId; resolvedCentroid=centroid
        resolvedPlotId=plotId; resolvedGarden=garden; resolvedUsername=farmUsername

        resolvedLbl.Text=("%s (Plot%d)  X=%.1f Z=%.1f  Ready"):format(farmUsername,plotId,centroid.X,centroid.Z)
        resolvedLbl.TextColor3=C.accent
        fireBtn.Active=true
        fireBtn.BackgroundColor3=C.dangerD
        fireBtn.TextColor3=C.danger
        locateBtn.Active=true; locateBtn.Text="🔍 Locate Target Plot"
    end)
end)

-- =====================
-- HIDE PLANTS (client-side lag fix)
-- Keeps first plant visible, hides the rest.
-- =====================
-- Client-side destroy: cannot be undone without rejoin.
hideBtn.MouseButton1Click:Connect(function()
    if not resolvedGarden then
        log("Locate a plot first", C.danger); return
    end
    local plants = resolvedGarden:FindFirstChild("Plants")
    if not plants then log("No Plants folder", C.danger); return end

    local uid = tostring(resolvedTargetId)
    local keepOne = nil
    local destroyed = 0
    for _,plant in ipairs(plants:GetChildren()) do
        if plant.Name:find(uid) then
            if not keepOne then
                keepOne = plant
            else
                pcall(function() plant:Destroy() end)
                destroyed = destroyed + 1
            end
        end
    end
    hideBtn.Text = ("💥 Destroyed %d (rejoin to restore)"):format(destroyed)
    hideBtn.BackgroundColor3 = Color3.fromRGB(65,45,90)
    hideBtn.Active = false
    log(("Destroyed %d plants client-side, kept %s"):format(destroyed, keepOne and keepOne.Name:sub(1,24) or "none"), C.purple)
    log("Rejoin server to restore visibility", C.muted)
end)

-- =====================
-- FIRE
-- =====================
local firing=false

local function placeSprinkler(centroid, plotId, hum, hrp)
    local sprTool = findTool("super sprinkler") or findTool("sprinkler")
    if not sprTool then return false, "no sprinkler tool" end
    local sprName = sprTool:GetAttribute("Sprinkler") or sprTool.Name
    hum:EquipTool(sprTool)
    task.wait(0.4)
    hrp.CFrame = CFrame.new(centroid + Vector3.new(0,5,0))
    task.wait(0.3)
    local ok,err = pcall(function()
        Networking.Place.PlaceSprinkler:Fire(centroid, sprName, sprTool, plotId)
    end)
    if not ok then return false, tostring(err):sub(1,50) end
    return true
end

local function fireWater(centroid, hum, hrp)
    local wTool = findTool("super watering can") or findTool("watering can")
    if not wTool then return false, "no watering can" end
    hum:EquipTool(wTool)
    task.wait(0.3)
    hrp.CFrame = CFrame.new(centroid + Vector3.new(0,5,0))
    task.wait(0.2)
    local ok,err = pcall(function()
        Networking.WateringCan.UseWateringCan:Fire(centroid, wTool.Name, wTool)
    end)
    if not ok then return false, tostring(err):sub(1,50) end
    return true
end

fireBtn.MouseButton1Click:Connect(function()
    if firing then
        firing = false
        fireBtn.Text = "Stopping..."
        return
    end
    if not resolvedCentroid then
        resolvedLbl.Text="Press Locate first"; resolvedLbl.TextColor3=C.danger; return
    end

    firing = true
    fireBtn.Text = "⏹ Stop"
    fireBtn.BackgroundColor3 = Color3.fromRGB(70,40,15)
    fireBtn.TextColor3 = C.gold

    task.spawn(function()
        local centroid = resolvedCentroid
        local plotId   = resolvedPlotId
        local garden   = resolvedGarden
        local char = lp.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then
            log("No humanoid on alt", C.danger); firing=false
            fireBtn.Text="🚨 Fire Emergency Regrow"
            fireBtn.BackgroundColor3=C.dangerD; fireBtn.TextColor3=C.danger; return
        end

        local sprinklerPlacedAt = 0
        local sprCount, waterCount = 0, 0

        -- Initial sprinkler (only if none present)
        if sprinklerExistsOnGarden(garden, centroid) then
            log("Sprinkler already on garden — skipping initial place", C.muted)
            sprinklerPlacedAt = os.clock()  -- assume fresh enough
        else
            local ok,err = placeSprinkler(centroid, plotId, hum, hrp)
            if ok then
                sprCount = sprCount + 1
                sprinklerPlacedAt = os.clock()
                log("Sprinkler placed ✓", C.accent)
            else
                log("Sprinkler place failed: "..tostring(err), C.danger)
            end
            task.wait(0.5)
        end

        -- 20 watering cycles, every 6s
        for i = 1, WATER_CYCLES do
            if not firing then log("Stopped by user", C.gold); break end

            -- Refresh sprinkler if expired AND none on garden
            if os.clock() - sprinklerPlacedAt >= SPRINKLER_LIFE then
                if not sprinklerExistsOnGarden(garden, centroid) then
                    log(("[cycle %d] Sprinkler expired — re-placing"):format(i), C.gold)
                    local ok,err = placeSprinkler(centroid, plotId, hum, hrp)
                    if ok then
                        sprCount = sprCount + 1
                        sprinklerPlacedAt = os.clock()
                        log("  Sprinkler ✓", C.accent)
                    else
                        log("  Sprinkler ERR: "..tostring(err), C.danger)
                    end
                    task.wait(0.4)
                else
                    -- still one there somehow, refresh timer
                    sprinklerPlacedAt = os.clock()
                end
            end

            resolvedLbl.Text = ("Watering %d/%d"):format(i, WATER_CYCLES)
            resolvedLbl.TextColor3 = C.water

            local ok,err = fireWater(centroid, hum, hrp)
            if ok then
                waterCount = waterCount + 1
                log(("  [%d/%d] Water ✓"):format(i,WATER_CYCLES), C.water)
            else
                log(("  [%d/%d] Water ERR: %s"):format(i,WATER_CYCLES,tostring(err)), C.danger)
            end

            -- Wait interval (unless last)
            if i < WATER_CYCLES then
                for s = WATER_INTERVAL, 1, -1 do
                    if not firing then break end
                    resolvedLbl.Text = ("Water %d/%d done — next in %ds"):format(i,WATER_CYCLES,s)
                    task.wait(1)
                end
            end
        end

        log(("── Complete: %d sprinkler(s), %d water fires ──"):format(sprCount,waterCount), C.gold)
        resolvedLbl.Text = ("Done! Sprinklers: %d  Waters: %d/%d"):format(sprCount,waterCount,WATER_CYCLES)
        resolvedLbl.TextColor3 = waterCount>0 and C.accent or C.gold

        firing = false
        fireBtn.Text = "🚨 Fire Emergency Regrow"
        fireBtn.BackgroundColor3 = C.dangerD
        fireBtn.TextColor3 = C.danger
    end)
end)

