-- multi-select chip row (48px tall = easy touch target)
local function selectRow(name, tbl, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 46)
    btn.BackgroundColor3 = C.row
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.LayoutOrder = order or 0
    btn.Parent = body
    corner(btn, 10)

    local box = Instance.new("Frame")
    box.Size = UDim2.new(0, 26, 0, 26)
    box.Position = UDim2.new(0, 12, 0.5, -13)
    box.BackgroundColor3 = C.off
    box.Parent = btn
    corner(box, 7)
    local tick = Instance.new("TextLabel")
    tick.Size = UDim2.new(1, 0, 1, 0); tick.BackgroundTransparency = 1
    tick.Text = "✓"; tick.TextColor3 = C.text; tick.Font = Enum.Font.GothamBold
    tick.TextSize = 18; tick.Visible = false; tick.Parent = box

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -52, 1, 0)
    lbl.Position = UDim2.new(0, 48, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = C.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 14
    lbl.Parent = btn

    local function selected()
        for _, v in ipairs(tbl) do if v == name then return true end end
        return false
    end
    local function render()
        local s = selected()
        box.BackgroundColor3 = s and C.accent or C.off
        tick.Visible = s
    end
    render()
    btn.MouseButton1Click:Connect(function()
        if selected() then
            for i = #tbl, 1, -1 do if tbl[i] == name then table.remove(tbl, i) end end
        else
            table.insert(tbl, name)
        end
        render()
    end)
end

-- toggle button (start/stop) 52px
local function toggleButton(labelOn, labelOff, getState, onToggle)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 50)
    btn.BackgroundColor3 = C.off
    btn.Text = labelOff
    btn.TextColor3 = C.text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 15
    btn.Parent = body
    corner(btn, 10)
    local function render()
        local s = getState()
        btn.Text = s and labelOn or labelOff
        btn.BackgroundColor3 = s and C.red or C.accent
    end
    render()
    btn.MouseButton1Click:Connect(function() onToggle(); render() end)
    return btn
end

