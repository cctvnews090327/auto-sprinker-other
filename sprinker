-- tool attribute keys the placeables use (checked in order)
local SPR_ATTR_KEYS = { "Sprinkler", "PlaceableItem", "ItemName", "GearName" }
local CAN_ATTR_KEYS = { "WateringCan", "PlaceableItem", "ItemName", "GearName" }

-- ---------- helpers ----------
local function getChar()
    local ch = lp.Character or lp.CharacterAdded:Wait()
    return ch, ch:FindFirstChildOfClass("Humanoid"), ch:FindFirstChild("HumanoidRootPart")
end

local function findMyPlot()
    local id = lp:GetAttribute("PlotId")
    if id and Workspace:FindFirstChild("Gardens") then
        local p = Workspace.Gardens:FindFirstChild("Plot" .. tostring(id))
        if p then return p end
    end
    if Workspace:FindFirstChild("Gardens") then
        for _, p in ipairs(Workspace.Gardens:GetChildren()) do
            if p:GetAttribute("Owner") == lp.Name then return p end
        end
    end
    return nil
end

local function plotHasPlants(plot)
    local plants = plot:FindFirstChild("Plants")
    if plants and #plants:GetChildren() > 0 then return true end
    -- fallback: any PlantArea child with plant models under the plot
    for _, d in ipairs(plot:GetDescendants()) do
        if d:GetAttribute("SeedName") then return true end
    end
    return false
end

local function plotOwnerName(plot)
    local o = plot:GetAttribute("Owner")
    if o then return o end
    local uid = plot:GetAttribute("OwnerUserId")
    if uid then
        local pl = Players:GetPlayerByUserId(uid)
        if pl then return pl.Name end
    end
    return plot.Name
end

-- other plots (not mine) that currently have plants/seeds
local function getTargetPlots()
    local mine = findMyPlot()
    local out = {}
    if not Workspace:FindFirstChild("Gardens") then return out end
    for _, plot in ipairs(Workspace.Gardens:GetChildren()) do
        if plot ~= mine and plotHasPlants(plot) then
            if (not CFG.targetOwner) or plotOwnerName(plot) == CFG.targetOwner then
                table.insert(out, plot)
            end
        end
    end
    return out
end

-- raycast a valid position onto a PlantArea part inside the given plot
local function findPlantAreaPos(plot)
    local areas = {}
    for _, part in ipairs(CS:GetTagged("PlantArea")) do
        if part:IsDescendantOf(plot) then table.insert(areas, part) end
    end
    if #areas == 0 then return nil end
    local part = areas[math.random(1, #areas)]
    -- cast straight down from just above the surface centre
    local top = part.Position + Vector3.new(0, 6, 0)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Include
    params.FilterDescendantsInstances = areas
    local hit = Workspace:Raycast(top, Vector3.new(0, -20, 0), params)
    if hit then return hit.Position, part end
    return part.Position + Vector3.new(0, part.Size.Y / 2, 0), part
end

local function toolByName(nameLower)
    for _, holder in ipairs({ lp.Character, lp.Backpack }) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                if t:IsA("Tool") and t.Name:lower():find(nameLower, 1, true) then
                    return t
                end
            end
        end
    end
    return nil
end

local function readAttr(tool, keys)
    for _, k in ipairs(keys) do
        local v = tool:GetAttribute(k)
        if v then return v end
    end
    return tool.Name
end

local function equip(tool)
    local _, hum = getChar()
    if hum and tool.Parent ~= lp.Character then
        pcall(function() hum:EquipTool(tool) end)
        task.wait(0.06)
    end
end

local function tpTo(pos)
    local _, _, hrp = getChar()
    if hrp then
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        task.wait(0.15)
    end
end

-- try several arg orders for PlaceSprinkler (confirmed remote path: Networking.Place.PlaceSprinkler)
local function firePlaceSprinkler(pos, itemName, tool)
    local place = Networking:FindFirstChild and nil -- Networking is a table, not instance
    local ok = false
    local remote = Networking.Place and Networking.Place.PlaceSprinkler
    if not remote then return false, "no PlaceSprinkler remote" end
    -- most-likely signature first, then fallbacks
    local attempts = {
        function() remote:Fire(pos, itemName, tool) end,
        function() remote:Fire(pos, tool) end,
        function() remote:Fire(tool, pos) end,
        function() remote:Fire(itemName, pos) end,
    }
    for _, fn in ipairs(attempts) do
        ok = pcall(fn)
        if ok then return true end
        task.wait(0.1)
    end
    return false
end

-- watering can: remote unconfirmed — try Place.PlaceWateringCan, else Activate()
local function fireWaterOnce(pos, itemName, tool)
    local remote = Networking.Place and (Networking.Place.PlaceWateringCan
                 or Networking.Place.UseWateringCan or Networking.Place.Water)
    if remote then
        local attempts = {
            function() remote:Fire(pos, itemName, tool) end,
            function() remote:Fire(pos, tool) end,
            function() remote:Fire(tool, pos) end,
        }
        for _, fn in ipairs(attempts) do
            if pcall(fn) then return true end
            task.wait(0.08)
        end
    end
    -- fallback: physically activate the equipped tool at the position
    tpTo(pos)
    return pcall(function() tool:Activate() end)
end

-- ============================================================
--  LOOP 1 — sprinkler rotation on friend plots
-- ============================================================
local sprIndex = 0
local function nextSprinklerName()
    if #CFG.sprinklers == 0 then return nil end
    sprIndex = (sprIndex % #CFG.sprinklers) + 1
    return CFG.sprinklers[sprIndex]
end

local function sprinklerLoop(log)
    while _G.GAG_SprRunning do
        local sprName = nextSprinklerName()
        if not sprName then
            log("no sprinkler selected"); task.wait(2)
        else
            local plots = getTargetPlots()
            if #plots == 0 then
                log("no planted friend plots found"); task.wait(3)
            else
                local plot = plots[1]
                local pos, area = findPlantAreaPos(plot)
                local tool = toolByName(sprName:lower())
                if not pos then
                    log("no PlantArea in " .. plotOwnerName(plot)); task.wait(3)
                elseif not tool then
                    log("no '" .. sprName .. "' in inventory"); task.wait(3)
                else
                    equip(tool)
                    tpTo(pos)
                    local itemName = readAttr(tool, SPR_ATTR_KEYS)
                    local ok = firePlaceSprinkler(pos, itemName, tool)
                    log((ok and "placed " or "FAILED ") .. sprName ..
                        " @ " .. plotOwnerName(plot))
                    -- wait out the 2-min duration before the next one
                    local t = 0
                    while _G.GAG_SprRunning and t < CFG.sprSeconds do
                        task.wait(1); t = t + 1
                    end
                end
            end
        end
    end
    log("sprinkler loop stopped")
end

-- ============================================================
--  LOOP 2 — watering can, 1 plant / 10s
-- ============================================================
local function waterLoop(log)
    while _G.GAG_CanRunning do
        local canName = CFG.cans[1]
        if not canName then
            log("no watering can selected"); task.wait(2)
        else
            local tool = toolByName(canName:lower())
            if not tool then
                log("no '" .. canName .. "' in inventory"); task.wait(3)
            else
                -- water a plant in the target plot (or first planted plot)
                local plots = getTargetPlots()
                local plot = plots[1] or findMyPlot()
                if plot then
                    local pos = findPlantAreaPos(plot)
                    if pos then
                        equip(tool)
                        local itemName = readAttr(tool, CAN_ATTR_KEYS)
                        local ok = fireWaterOnce(pos, itemName, tool)
                        log(ok and "watered (all grouped)" or "water FAILED")
                    end
                end
                local t = 0
                while _G.GAG_CanRunning and t < CFG.canSeconds do
                    task.wait(1); t = t + 1
                end
            end
        end
    end
    log("watering loop stopped")
end

-- ============================================================
--  DISCOVER REMOTES — capture exact args by placing manually
-- ============================================================
local function discover(log)
    log("Hook ready — now MANUALLY place a sprinkler & swing a can")
    local function ser(v)
        local ty = typeof(v)
        if ty == "Vector3" then return ("V3(%.1f,%.1f,%.1f)"):format(v.X, v.Y, v.Z)
        elseif ty == "Instance" then return ("Inst<%s:%s>"):format(v.ClassName, v.Name)
        elseif ty == "string" then return '"' .. v .. '"'
        else return ty .. "(" .. tostring(v) .. ")" end
    end
    local function want(n) n = n:lower(); return n:find("place") or n:find("water") or n:find("sprinkler") end
    -- prefer hookmetamethod (executor-safe), fall back to raw metatable
    local installed = false
    if hookmetamethod then
        local old; old = hookmetamethod(game, "__namecall", function(self, ...)
            local m = getnamecallmethod and getnamecallmethod() or ""
            if m == "Fire" or m == "FireServer" or m == "InvokeServer" then
                local ok, full = pcall(function() return self:GetFullName() end)
                if ok and want(full) then
                    local a, parts = { ... }, {}
                    for i, v in ipairs(a) do parts[i] = "[" .. i .. "]" .. ser(v) end
                    log("REMOTE " .. full .. " " .. table.concat(parts, " "))
                end
            end
            return old(self, ...)
        end)
        installed = true
    elseif getrawmetatable then
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local m = getnamecallmethod()
            if m == "Fire" or m == "FireServer" then
                local full = self:GetFullName()
                if want(full) then
                    local a, parts = { ... }, {}
                    for i, v in ipairs(a) do parts[i] = "[" .. i .. "]" .. ser(v) end
                    log("REMOTE " .. full .. " " .. table.concat(parts, " "))
                end
            end
            return old(self, ...)
        end)
        setreadonly(mt, true); installed = true
    end
    if not installed then log("no hook function in this executor") end
end

