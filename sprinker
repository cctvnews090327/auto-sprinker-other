local function getTargetGarden(targetUserId, username)
    for _,g in ipairs(Workspace.Gardens:GetChildren()) do
        local ownerId = g:GetAttribute("OwnerUserId")
        local owner   = g:GetAttribute("Owner")
        if tostring(ownerId)==tostring(targetUserId) or owner==username then
            return g
        end
    end
    local uid=tostring(targetUserId)
    for _,g in ipairs(Workspace.Gardens:GetChildren()) do
        local plants=g:FindFirstChild("Plants")
        if plants then
            for _,p in ipairs(plants:GetChildren()) do
                if p.Name:find(uid) then return g end
            end
        end
    end
    return nil
end

local function getTargetPlotCentroid(garden, targetUserId)
    local uid=tostring(targetUserId)
    local sumX,sumZ,count = 0,0,0
    local plotY = 142.36
    local plants = garden and garden:FindFirstChild("Plants")
    if not plants then return nil end
    for _,plant in ipairs(plants:GetChildren()) do
        if plant.Name:find(uid) then
            local pp = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart")
            if pp then
                sumX=sumX+pp.Position.X
                sumZ=sumZ+pp.Position.Z
                plotY=pp.Position.Y
                count=count+1
            end
        end
    end
    if count==0 then return nil end
    log(("Found %d plants for target"):format(count),C.accent)
    return Vector3.new(sumX/count, plotY, sumZ/count), count
end

local function findTool(namePattern)
    local bp = lp:FindFirstChildOfClass("Backpack")
    local char = lp.Character
    for _,container in ipairs({char,bp}) do
        if container then
            for _,item in ipairs(container:GetChildren()) do
                if item:IsA("Tool") and item.Name:lower():find(namePattern:lower()) then
                    return item
                end
            end
        end
    end
    return nil
end

local function findSprinklerSpot(garden, centroid)
    if not garden then return centroid end
    local plants = garden:FindFirstChild("Plants")
    if not plants then return centroid end

    local function plantAt(x, z, radius)
        local pt = Vector3.new(x, 0, z)
        for _,plant in ipairs(plants:GetChildren()) do
            local pp = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart")
            if pp then
                local flat = Vector3.new(pp.Position.X, 0, pp.Position.Z)
                if (pt - flat).Magnitude < radius then return true end
            end
        end
        return false
    end

    local offsets = {
        Vector3.new(0,0,0),
        Vector3.new(2,0,0), Vector3.new(-2,0,0),
        Vector3.new(0,0,2), Vector3.new(0,0,-2),
        Vector3.new(3,0,3), Vector3.new(-3,0,3),
        Vector3.new(3,0,-3), Vector3.new(-3,0,-3),
    }
    for _,off in ipairs(offsets) do
        local pos = centroid + off
        if not plantAt(pos.X, pos.Z, 1.5) then
            return pos
        end
    end
    return centroid
end

local function sprinklerExistsOnGarden(garden, centroid, radius)
    radius = radius or 40
    if not garden then return false end
    for _,d in ipairs(garden:GetDescendants()) do
        if (d:IsA("Model") or d:IsA("BasePart")) and d.Name:lower():find("sprinkler") then
            local pos
            if d:IsA("Model") then
                local pp = d.PrimaryPart or d:FindFirstChildWhichIsA("BasePart")
                pos = pp and pp.Position
            else pos = d.Position end
            if pos and (Vector3.new(pos.X,0,pos.Z)-Vector3.new(centroid.X,0,centroid.Z)).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

