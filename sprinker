local firing=false

local function placeSprinkler(centroid, plotId, hum, hrp, garden)
    local sprTool = findTool("super sprinkler") or findTool("sprinkler")
    if not sprTool then return false, "no sprinkler tool" end
    local sprName = sprTool:GetAttribute("Sprinkler") or sprTool.Name

    local placePos = findSprinklerSpot(garden, centroid)

    hum:EquipTool(sprTool)
    task.wait(0.4)
    hrp.CFrame = CFrame.new(placePos + Vector3.new(0,5,0))
    task.wait(0.3)
    local ok,err = pcall(function()
        Networking.Place.PlaceSprinkler:Fire(placePos, sprName, sprTool, plotId)
    end)
    if not ok then return false, tostring(err):sub(1,50) end
    return true
end

local function fireWater(centroid, hum, hrp)
    local wTool = findTool("super watering can") or findTool("watering can")
    if not wTool then return false, "no watering can" end
    hum:EquipTool(wTool)
    task.wait(0.3)
    hrp.CFrame = CFrame.new(centroid + Vector3.new(0,5,0))
    task.wait(0.2)
    local ok,err = pcall(function()
        Networking.WateringCan.UseWateringCan:Fire(centroid, wTool.Name, wTool)
    end)
    if not ok then return false, tostring(err):sub(1,50) end
    return true
end

fireBtn.MouseButton1Click:Connect(function()
    if firing then
        firing = false
        fireBtn.Text = "Stopping..."
        return
    end
    if not resolvedCentroid then
        resolvedLbl.Text="Press Locate first"; resolvedLbl.TextColor3=C.danger; return
    end

    firing = true
    fireBtn.Text = "⏹ Stop"
    fireBtn.BackgroundColor3 = Color3.fromRGB(70,40,15)
    fireBtn.TextColor3 = C.gold

    task.spawn(function()
        local centroid = resolvedCentroid
        local plotId   = resolvedPlotId
        local garden   = resolvedGarden
        local totalCycles = WATER_CYCLES
        local intervalSec = WATER_INTERVAL
        local char = lp.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then
            log("No humanoid on alt", C.danger); firing=false
            fireBtn.Text="🚨 Fire Emergency Regrow"
            fireBtn.BackgroundColor3=C.dangerD; fireBtn.TextColor3=C.danger; return
        end

        local sprinklerPlacedAt = 0
        local sprCount, waterCount = 0, 0

        if sprinklerExistsOnGarden(garden, centroid) then
            log("Sprinkler already on garden — skipping initial place", C.muted)
            sprinklerPlacedAt = os.clock()
        else
            local ok,err = placeSprinkler(centroid, plotId, hum, hrp, garden)
            if ok then
                sprCount = sprCount + 1
                sprinklerPlacedAt = os.clock()
                log("Sprinkler placed ✓", C.accent)
                task.wait(0.5)
                if not sprinklerExistsOnGarden(garden, centroid) then
                    log("Initial sprinkler didn't register — retrying", C.gold)
                    local ok2,err2 = placeSprinkler(centroid, plotId, hum, hrp, garden)
                    if ok2 then
                        sprCount = sprCount + 1
                        sprinklerPlacedAt = os.clock()
                        log("Retry ✓", C.accent)
                    else
                        log("Retry ERR: "..tostring(err2), C.danger)
                    end
                    task.wait(0.5)
                end
            else
                log("Sprinkler place failed: "..tostring(err), C.danger)
                task.wait(0.5)
            end
        end

        for i = 1, totalCycles do
            if not firing then log("Stopped by user", C.gold); break end

            local needSprinkler = false
            local reason = ""
            if not sprinklerExistsOnGarden(garden, centroid) then
                needSprinkler = true; reason = "missing"
            elseif os.clock() - sprinklerPlacedAt >= SPRINKLER_LIFE then
                needSprinkler = true; reason = "expired"
            end

            if needSprinkler then
                log(("[cycle %d] Sprinkler %s — placing"):format(i, reason), C.gold)
                local ok,err = placeSprinkler(centroid, plotId, hum, hrp, garden)
                if ok then
                    sprCount = sprCount + 1
                    sprinklerPlacedAt = os.clock()
                    log("  Sprinkler ✓", C.accent)
                    task.wait(0.4)
                    if not sprinklerExistsOnGarden(garden, centroid) then
                        log("  Sprinkler didn't register — retrying", C.gold)
                        local ok2,err2 = placeSprinkler(centroid, plotId, hum, hrp, garden)
                        if ok2 then
                            sprCount = sprCount + 1
                            sprinklerPlacedAt = os.clock()
                            log("  Sprinkler retry ✓", C.accent)
                        else
                            log("  Retry ERR: "..tostring(err2), C.danger)
                        end
                        task.wait(0.4)
                    end
                else
                    log("  Sprinkler ERR: "..tostring(err), C.danger)
                end
            end

            resolvedLbl.Text = ("Watering %d/%d"):format(i, totalCycles)
            resolvedLbl.TextColor3 = C.water

            local ok,err = fireWater(centroid, hum, hrp)
            if ok then
                waterCount = waterCount + 1
                log(("  [%d/%d] Water ✓"):format(i,totalCycles), C.water)
            else
                log(("  [%d/%d] Water ERR: %s"):format(i,totalCycles,tostring(err)), C.danger)
            end

            if i < totalCycles then
                for s = intervalSec, 1, -1 do
                    if not firing then break end
                    resolvedLbl.Text = ("Water %d/%d done — next in %ds"):format(i,totalCycles,s)
                    task.wait(1)
                end
            end
        end

        log(("── Complete: %d sprinkler(s), %d water fires ──"):format(sprCount,waterCount), C.gold)
        resolvedLbl.Text = ("Done! Sprinklers: %d  Waters: %d/%d"):format(sprCount,waterCount,totalCycles)
        resolvedLbl.TextColor3 = waterCount>0 and C.accent or C.gold

        firing = false
        fireBtn.Text = "🚨 Fire Emergency Regrow"
        fireBtn.BackgroundColor3 = C.dangerD
        fireBtn.TextColor3 = C.danger
    end)
end)

